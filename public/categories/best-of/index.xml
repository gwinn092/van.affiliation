    <item>
      <title>Best Internet Setup for Van Life</title>
      <link>http://localhost:1313/best-of/van-internet/</link>
      <pubDate>Sat, 21 Feb 2026 00:00:00 +0000</pubDate>
      
      <guid>http://localhost:1313/best-of/van-internet/</guid>
